rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.email in [
        "irfan.karor.mi@gmail.com",
        "webservicesaplus@gmail.com",
        "aplusacademylahore@gmail.com"
      ];
    }

    function isBlogManager() {
      return isAdmin() || (
        signedIn()
        && request.auth.token.email is string
        && firestore.exists(/databases/(default)/documents/blogEditors/$(request.auth.token.email))
      );
    }

    match /teachers/{teacherId}/{fileName} {
      allow read: if true;
      allow write: if isAdmin()
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /teacher-applications/{uid}/{fileName} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow write: if signedIn()
        && (request.auth.uid == uid || isAdmin())
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /blog-images/{slug}/{fileName} {
      allow read: if true;
      allow write: if isBlogManager()
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
